{
  "name": "os-lang",
  "displayName": "OS-Lang",
  "description": "Syntax highlighting and language support for OS-Lang bare-metal systems language.",
  "version": "0.1.0",
  "publisher": "HamzaTehseenCheema",
  "repository": {
    "type": "git",
    "url": "https://github.com/Techmastergojo/os-lang"
  },
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "os",
        "aliases": ["OS-Lang", "os-lang"],
        "extensions": [".os"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "os",
        "scopeName": "source.os",
        "path": "./syntaxes/os.tmLanguage.json"
      }
    ]
  }
}
