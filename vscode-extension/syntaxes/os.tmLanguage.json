{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "OS-Lang",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#decorators"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.os",
          "match": "#.*$"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.os",
          "match": "\\b(if|else|while|return|pass|asm|hwmap|at)\\b"
        },
        {
          "name": "storage.type.os",
          "match": "\\b(def|var|struct)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.os",
          "match": "\\b(u8|u16|u32|u64|i8|i16|i32|i64|usize|isize|ptr|True|False)\\b"
        }
      ]
    },
    "decorators": {
      "patterns": [
        {
          "name": "entity.name.function.decorator.os",
          "match": "@(unsafe|packed|naked|no_mangle|align)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.os",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.os",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.os",
          "match": "\\b0x[0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.decimal.os",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.os",
          "match": "(=|\\+|-|\\*|/|&|\\||\\^|<<|>>|==|!=|<|>|<=|>=|\\bas\\b)"
        }
      ]
    }
  },
  "scopeName": "source.os"
}
